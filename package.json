{
  "name": "brainotix-site",
  "version": "1.0.0",
  "private": true,
  "description": "Brainotix Solutions marketing site + contact backend",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i src/input.css -o assets/styles.css --minify",
    "watch:css": "tailwindcss -i src/input.css -o assets/styles.css --watch",
    "build:assets": "node scripts/generate-assets.js",
    "build": "npm run build:css && npm run build:assets"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.17"
  }
}
