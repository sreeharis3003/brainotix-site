# ----- Brainotix contact backend configuration -----
# Copy this file to ".env" and fill in real values, then restart the server.
# The .env file is git-ignored and is NEVER served to the browser.

# Port the server listens on
PORT=3000

# --- SMTP (email delivery) ---
# Works with any SMTP provider. Examples:
#   Gmail:      SMTP_HOST=smtp.gmail.com   PORT=587  (use a Google "App Password", not your login password)
#   Office365:  SMTP_HOST=smtp.office365.com PORT=587
#   Zoho:       SMTP_HOST=smtp.zoho.in     PORT=465  SECURE=true
#   SendGrid:   SMTP_HOST=smtp.sendgrid.net PORT=587  USER=apikey  PASS=<your-api-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where enquiry notifications are sent (defaults to SMTP_USER if blank)
CONTACT_TO=contactus@brainotix.com
# The "from" address shown on outgoing mail (defaults to SMTP_USER if blank)
CONTACT_FROM=

# --- Optional: only needed if the HTML is hosted on a DIFFERENT origin ---
# e.g. https://www.brainotix.com  (leave blank when the server serves the page itself)
ALLOWED_ORIGIN=
